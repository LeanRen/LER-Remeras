---
interface Props { id: number; titulo: string; precio: string; imagen: string; stock: number; }
const { id, titulo, precio, imagen, stock } = Astro.props;
---
<div class="group relative bg-[#0a0a0a] border border-white/5 flex flex-col h-full transition-all duration-500 hover:border-[#007BFF]/30">
    <a href={`/productos/${id}`} class="relative block aspect-[3/4] overflow-hidden bg-black">
        <img src={imagen} alt={titulo} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
        {stock <= 0 && (
            <div class="absolute inset-0 bg-black/80 flex items-center justify-center z-20">
                <span class="text-[9px] font-black uppercase tracking-[0.4em] border border-white/20 text-white/50 px-6 py-3">SOLD OUT</span>
            </div>
        )}
    </a>
    <div class="p-5 flex flex-col flex-1">
        <h3 class="text-[9px] font-black uppercase text-white/30 tracking-[0.2em] mb-1 group-hover:text-[#007BFF] transition-colors">{titulo}</h3>
        <p class="text-xl font-raw italic text-white tracking-tighter mb-4">${precio}</p>
        <a href={`/productos/${id}`} class={`w-full py-4 text-center text-[9px] font-black tracking-[0.3em] uppercase transition-all ${stock > 0 ? "bg-white text-black hover:bg-[#007BFF] hover:text-white" : "bg-white/5 text-white/20 cursor-not-allowed"}`}>
            {stock > 0 ? "Ver Detalle" : "Sin Stock"}
        </a>
    </div>
</div>