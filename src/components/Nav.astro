---
const links = [
  { name: 'INICIO', hash: '/' },
  { name: 'PRODUCTOS', hash: '/productos' },
  { name: 'CONTACTO', hash: '#contacto' },
];
---
<nav class="fixed w-full z-[100] bg-black/60 backdrop-blur-xl border-b border-white/5">
  <div class="max-w-7xl mx-auto px-6 md:px-12 flex justify-between items-center h-20 md:h-24">
    <a href="/" class="flex items-center group">
      <span class="text-xl md:text-2xl font-raw tracking-tighter text-white group-hover:text-[#007BFF] transition-colors">
        L&A <span class="text-[#007BFF] group-hover:text-white transition-colors">REMERAS</span>
      </span>
    </a>
    <div class="hidden md:flex items-center gap-10">
      {links.map(link => (
        <a href={link.hash} class="text-[10px] font-black tracking-[0.3em] text-white/50 hover:text-[#007BFF] transition-all italic uppercase">{link.name}</a>
      ))}
      <button id="open-cart-nav" class="text-[10px] font-black tracking-[0.3em] bg-white text-black px-6 py-3 hover:bg-[#007BFF] hover:text-white transition-all">CARRITO</button>
    </div>
  </div>
</nav>