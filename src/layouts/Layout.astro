---
interface Props {
	title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Syncopate:wght@400;700&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body class="bg-[#050505] text-white antialiased selection:bg-[#007BFF] selection:text-white">
		<slot />
		<style is:global>
			:root {
				--accent: #007BFF;
				--bg-dark: #050505;
				--border-white: rgba(255, 255, 255, 0.1);
			}
			html { font-family: 'Inter', sans-serif; scroll-behavior: smooth; }
			.font-raw { font-family: 'Syncopate', sans-serif; text-transform: uppercase; font-style: italic; font-weight: 700; letter-spacing: -0.05em; }
			::-webkit-scrollbar { width: 6px; }
			::-webkit-scrollbar-track { background: #050505; }
			::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 10px; }
		</style>
	</body>
</html>