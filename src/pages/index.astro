---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CardRemera from '../components/CardRemera.astro';
import Card from '../components/Card.astro';
import { db, Producto, desc } from 'astro:db';

const novedades = await db.select().from(Producto).orderBy(desc(Producto.id)).limit(4);

const destacadas = [
  { nombre: "Buzos & Hoodies", slug: "BUZOS", img: "https://images.unsplash.com/photo-1556821840-3a63f95609a7?q=80&w=1887" },
  { nombre: "Rock & Música", slug: "REMERAS ROCK/MUSICA INTERNACIONAL", img: "https://images.unsplash.com/photo-1564859228273-274232fdb516?q=80&w=1887" },
  { nombre: "Packs Especiales", slug: "PACKS DE REMERAS", img: "https://images.unsplash.com/photo-1554412933-514a83d2f3c8?q=80&w=1887" }
];
---

<Layout title="LER REMERAS | ESTILO ÚNICO">
    <Nav />
    <Card /> 
    <main class="bg-[#050505] min-h-screen text-white">
        
        <section class="relative h-[90vh] flex items-center justify-center overflow-hidden border-b border-white/5">
            <div class="absolute inset-0 z-0">
                <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-[#050505] z-10"></div>
                <img 
                    src="https://images.unsplash.com/photo-1558769132-cb1aea458c5e?q=80&w=1974" 
                    class="w-full h-full object-cover opacity-40 grayscale scale-105"
                    alt="Hero Background"
                />
            </div>

            <div class="relative z-20 text-center px-6">
                <span class="text-[10px] font-black tracking-[0.5em] text-[#007BFF] uppercase mb-4 block animate-reveal" style="animation-delay: 0.2s;">
                    Remeras Personalizadas y Únicas
                </span>
                <h1 class="text-6xl md:text-9xl font-raw leading-[0.85] mb-8 animate-reveal">
                    ESTILO <br/> <span class="text-outline">ÚNICO</span>
                </h1>
                <div class="flex flex-col md:flex-row gap-4 justify-center items-center animate-reveal" style="animation-delay: 0.4s;">
                    <a href="/productos" class="bg-white text-black px-10 py-4 font-black text-[10px] tracking-[0.3em] uppercase hover:bg-[#007BFF] hover:text-white transition-all w-full md:w-auto text-center">
                        Ver Tienda
                    </a>
                    <a href="#novedades" class="border border-white/20 px-10 py-4 font-black text-[10px] tracking-[0.3em] uppercase hover:bg-white hover:text-black transition-all w-full md:w-auto text-center">
                        Novedades
                    </a>
                </div>
            </div>

            <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-20">
                <div class="w-[1px] h-12 bg-white"></div>
            </div>
        </section>

        <section id="novedades" class="py-24 px-6 max-w-7xl mx-auto">
            <div class="flex justify-between items-end mb-16">
                <div>
                    <h2 class="text-4xl md:text-6xl font-raw italic tracking-tighter">Nuevos <span class="text-[#007BFF]">Lanzamientos</span></h2>
                    <p class="text-[10px] text-white/30 tracking-[0.2em] uppercase mt-2">Lo último en LER REMERAS</p>
                </div>
                <a href="/productos" class="text-[9px] font-black tracking-widest uppercase border-b border-[#007BFF] text-[#007BFF] pb-1 hover:text-white hover:border-white transition-colors">
                    Ver todo
                </a>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                {novedades.map((p) => (
                    <CardRemera 
                        id={p.id} 
                        titulo={p.titulo} 
                        precio={p.precio.toString()} 
                        imagen={p.imagen} 
                        stock={p.stock}
                    />
                ))}
            </div>
        </section>

        <section class="pb-24 px-6 max-w-7xl mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 h-[600px] md:h-[500px]">
                {destacadas.map((cat) => (
                    <a href={`/productos?cat=${cat.slug}`} class="group relative overflow-hidden bg-black border border-white/5 h-full">
                        <img src={cat.img} class="absolute inset-0 w-full h-full object-cover opacity-50 grayscale group-hover:scale-110 group-hover:opacity-70 transition-all duration-700" alt={cat.nombre} />
                        <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent"></div>
                        <div class="absolute bottom-8 left-8">
                            <h3 class="text-xl font-raw text-white group-hover:text-[#007BFF] transition-colors">{cat.nombre}</h3>
                            <span class="text-[9px] font-black tracking-widest text-white/40 group-hover:text-white">EXPLORAR →</span>
                        </div>
                    </a>
                ))}
            </div>
        </section>
    </main>
    <Footer />
</Layout>

<style>
    .text-outline {
        color: transparent;
        -webkit-text-stroke: 1px rgba(255, 255, 255, 0.4);
    }

    @keyframes reveal {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-reveal {
        animation: reveal 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
</style>